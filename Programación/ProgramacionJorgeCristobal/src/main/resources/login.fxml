<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.programacionjorgecristobal.controller.LoginController">

    <Label text="Bienvenido a TechStock" style="-fx-font-size: 20px;"/>
    <TextField fx:id="txtUser" promptText="Nombre de usuario" maxWidth="200"/>
    <PasswordField fx:id="txtPass" promptText="Contraseña" maxWidth="200"/>

    <Label fx:id="lblError" textFill="RED"/>
    <Button text="Entrar" onAction="#hacerLogin"/>
</VBox>